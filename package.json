{
  "private": true,
  "scripts": {
    "typecheck": "pnpm run npm_package:typecheck && pnpm run playground:typecheck",
    "playground:typecheck": "tsc --noEmit --pretty",
    "npm_package:typecheck": "pnpm run --filter ckeditor5-phoenix typecheck",
    "npm_package:watch": "pnpm run --filter ckeditor5-phoenix watch",
    "npm_package:build": "pnpm run --filter ckeditor5-phoenix build",
    "npm_package:test": "pnpm run --filter ckeditor5-phoenix test",
    "npm_package:test:watch": "pnpm run --filter ckeditor5-phoenix test:watch"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.15.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/phoenix": "^1.6.6",
    "chromedriver": "^146.0.0",
    "ckeditor5": "^47.6.0",
    "ckeditor5-premium-features": "^47.6.0",
    "esbuild": "^0.25.5",
    "eslint": "^9.29.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "phoenix": "^1.7.21",
    "phoenix_live_view": "1.1.28",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix"
    ],
    "*.{ex,exs}": [
      "mix format --check-formatted",
      "mix credo --strict"
    ]
  }
}
